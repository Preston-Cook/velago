{
  "extends": ["airbnb", "prettier", "next/core-web-vitals"],
  "plugins": ["prettier"],
  "rules": {
    "prettier/prettier": ["warn", { "singleQuote": true }],
    "react/jsx-filename-extension": [
      2,
      { "extensions": [".js", ".jsx", ".ts", ".tsx"] }
    ],
    "react/jsx-curly-brace-presence": "warn"
  },
  "globals": {
    "React": true
  },
  "env": {
    "es2024": true
  }
}
